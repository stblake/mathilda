Cell[CellGroupData[{

Cell["Theorem 2", "Section",
 CellChangeTimes->{{3.963957881173242*^9, 
  3.963957887012724*^9}},ExpressionUUID->"e367f3ec-239a-4872-8c21-\
dd8d566d5566"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"GoursatTheorem2", "::", "usage"}], "=", 
    "\"\<GoursatTheorem2[f, r, t, u] attempts to reduce an integral where \
F(t) satisfies the sum condition F + F(S1) + F(S2) + F(S3) == 0. It \
decomposes F into three components and applies GoursatTheorem1 to \
each.\>\""}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"ClearAll", "[", "GoursatTheorem2", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"GoursatTheorem2", "[", 
   RowBox[{"f_", ",", "r_", ",", "t_", ",", "u_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "roots", ",", "finiteRoots", ",", "degree", ",", "pairings", ",", "S1", 
      ",", "S2", ",", "S3", ",", "f1", ",", "f2", ",", "f3", ",", "sol1", ",",
       "sol2", ",", "sol3"}], "}"}], ",", "\[IndentingNewLine]", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Step", " ", "1"}], ":", " ", 
       RowBox[{
       "Find", " ", "the", " ", "three", " ", "involutions", " ", "S1"}]}], 
      ",", "S2", ",", 
      RowBox[{"S3", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"degree", "=", 
      RowBox[{"Exponent", "[", 
       RowBox[{"r", ",", "t"}], "]"}]}], ";", 
     RowBox[{"(*", " ", 
      RowBox[{"Get", " ", "the", " ", "degree", " ", "of", " ", "the", " ", 
       RowBox[{"polynomial", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{"Initialize", " ", "roots", " ", 
       RowBox[{"variable", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"roots", "=", 
      RowBox[{"{", "}"}]}], ";", " ", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Which", "[", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{"Case", " ", "1"}], ":", " ", 
        RowBox[{"R", 
         RowBox[{"(", "t", ")"}], " ", "is", " ", "a", " ", 
         RowBox[{"Quartic", "."}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"degree", "==", "4"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"roots", "=", 
         RowBox[{"t", "/.", " ", 
          RowBox[{"Solve", "[", 
           RowBox[{
            RowBox[{"r", "==", "0"}], ",", "t"}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"Length", "[", "roots", "]"}], "!=", "4"}], "||", 
           RowBox[{
            RowBox[{"Length", "[", 
             RowBox[{"DeleteDuplicates", "[", "roots", "]"}], "]"}], "!=", 
            "4"}]}], ",", 
          RowBox[{
           RowBox[{
           "Print", "[", 
            "\"\<Error: Quartic polynomial R(t) must have 4 distinct roots.\>\
\"", "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"Return", "[", "$Failed", "]"}], ";"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{"\"\<Quartic detected. Roots: \>\"", ",", "roots"}], "]"}], 
        ";"}], ",", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{"Case", " ", "2"}], ":", " ", 
         RowBox[{"R", 
          RowBox[{"(", "t", ")"}], " ", "is", " ", "a", " ", 
          RowBox[{"Cubic", "."}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"degree", "==", "3"}], ",", 
       RowBox[{
        RowBox[{"finiteRoots", "=", 
         RowBox[{"t", "/.", " ", 
          RowBox[{"Solve", "[", 
           RowBox[{
            RowBox[{"r", "==", "0"}], ",", "t"}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"Length", "[", "finiteRoots", "]"}], "!=", "3"}], "||", 
           RowBox[{
            RowBox[{"Length", "[", 
             RowBox[{"DeleteDuplicates", "[", "finiteRoots", "]"}], "]"}], "!=",
             "3"}]}], ",", 
          RowBox[{
           RowBox[{
           "Print", "[", 
            "\"\<Error: Cubic polynomial R(t) must have 3 distinct \
roots.\>\"", "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"Return", "[", "$Failed", "]"}], ";"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"roots", "=", 
         RowBox[{"Append", "[", 
          RowBox[{"finiteRoots", ",", "Infinity"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{
         "\"\<Cubic detected. Treating as a quartic with roots: \>\"", ",", 
          "roots"}], "]"}], ";"}], ",", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{"Default", " ", 
         RowBox[{"Case", ":", " ", 
          RowBox[{"Invalid", " ", 
           RowBox[{"Degree", "."}]}]}]}], " ", "*)"}], "True", ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
        "Print", "[", 
         "\"\<Error: R(t) must be a polynomial of degree 3 or 4.\>\"", "]"}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"Return", "[", "$Failed", "]"}]}]}], "\[IndentingNewLine]", 
      "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"pairings", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"roots", "[", 
             RowBox[{"[", "1", "]"}], "]"}], ",", 
            RowBox[{"roots", "[", 
             RowBox[{"[", "2", "]"}], "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"roots", "[", 
             RowBox[{"[", "3", "]"}], "]"}], ",", 
            RowBox[{"roots", "[", 
             RowBox[{"[", "4", "]"}], "]"}]}], "}"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"roots", "[", 
             RowBox[{"[", "1", "]"}], "]"}], ",", 
            RowBox[{"roots", "[", 
             RowBox[{"[", "3", "]"}], "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"roots", "[", 
             RowBox[{"[", "2", "]"}], "]"}], ",", 
            RowBox[{"roots", "[", 
             RowBox[{"[", "4", "]"}], "]"}]}], "}"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"roots", "[", 
             RowBox[{"[", "1", "]"}], "]"}], ",", 
            RowBox[{"roots", "[", 
             RowBox[{"[", "4", "]"}], "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"roots", "[", 
             RowBox[{"[", "2", "]"}], "]"}], ",", 
            RowBox[{"roots", "[", 
             RowBox[{"[", "3", "]"}], "]"}]}], "}"}]}], "}"}]}], "}"}]}], ";",
      "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"S1", ",", "S2", ",", "S3"}], "}"}], "=", 
      RowBox[{
       RowBox[{
        RowBox[{"S", "[", 
         RowBox[{"t", ",", "#"}], "]"}], "&"}], "/@", "pairings"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{
      "\"\<Involutions found: S1=\>\"", ",", "S1", ",", "\"\<, S2=\>\"", ",", 
       "S2", ",", "\"\<, S3=\>\"", ",", "S3"}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{"Step", " ", "2"}], ":", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"Verify", " ", "the", " ", "condition", " ", "F"}], " ", "+",
          " ", 
         RowBox[{"F", 
          RowBox[{"(", "S1", ")"}]}], " ", "+", " ", 
         RowBox[{"F", 
          RowBox[{"(", "S2", ")"}]}], " ", "+", " ", 
         RowBox[{"F", 
          RowBox[{"(", "S3", ")"}]}]}], " ", "==", " ", "0"}]}], " ", "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<\\nStep 2: Verifying the summation condition...\>\"", 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Simplify", "[", 
         RowBox[{"Cancel", "[", 
          RowBox[{"Together", "[", 
           RowBox[{"f", "+", 
            RowBox[{"(", 
             RowBox[{"f", "/.", " ", 
              RowBox[{"t", "->", "S1"}]}], ")"}], "+", 
            RowBox[{"(", 
             RowBox[{"f", "/.", " ", 
              RowBox[{"t", "->", "S2"}]}], ")"}], "+", 
            RowBox[{"(", 
             RowBox[{"f", "/.", " ", 
              RowBox[{"t", "->", "S3"}]}], ")"}]}], "]"}], "]"}], "]"}], "!=",
         "0"}], ",", 
       RowBox[{
        RowBox[{
        "Print", "[", 
         "\"\<Error: The function F(t) does not satisfy the summation \
condition. Theorem 2 does not apply.\>\"", "]"}], ";", "\[IndentingNewLine]", 
        
        RowBox[{"Return", "[", 
         RowBox[{
          RowBox[{"Defer", "[", "Integrate", "]"}], "[", 
          RowBox[{
           RowBox[{"f", "/", 
            RowBox[{"Sqrt", "[", "r", "]"}]}], ",", "t"}], "]"}], "]"}], 
        ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "\"\<Condition met.\>\"", "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"Step", " ", "3"}], ":", " ", 
        RowBox[{"Decompose", " ", "f", " ", "into", " ", "f1"}]}], ",", "f2", 
       ",", 
       RowBox[{"f3", " ", "based", " ", "on", " ", "the", " ", "group", " ", 
        RowBox[{"structure", "."}]}]}], " ", "*)"}], 
     RowBox[{
     "Print", "[", 
      "\"\<Step 3: Decomposing F(t) into three components f1, f2, f3...\>\"", 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"f1", "=", 
      RowBox[{"Simplify", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"f", "-", 
          RowBox[{"(", 
           RowBox[{"f", "/.", " ", 
            RowBox[{"t", "->", "S1"}]}], ")"}], "-", 
          RowBox[{"(", 
           RowBox[{"f", "/.", " ", 
            RowBox[{"t", "->", "S2"}]}], ")"}], "+", 
          RowBox[{"(", 
           RowBox[{"f", "/.", " ", 
            RowBox[{"t", "->", "S3"}]}], ")"}]}], ")"}], "/", "4"}], "]"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"f2", "=", 
      RowBox[{"Simplify", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"f", "-", 
          RowBox[{"(", 
           RowBox[{"f", "/.", " ", 
            RowBox[{"t", "->", "S1"}]}], ")"}], "+", 
          RowBox[{"(", 
           RowBox[{"f", "/.", " ", 
            RowBox[{"t", "->", "S2"}]}], ")"}], "-", 
          RowBox[{"(", 
           RowBox[{"f", "/.", " ", 
            RowBox[{"t", "->", "S3"}]}], ")"}]}], ")"}], "/", "4"}], "]"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"f3", "=", 
      RowBox[{"Simplify", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"f", "+", 
          RowBox[{"(", 
           RowBox[{"f", "/.", " ", 
            RowBox[{"t", "->", "S1"}]}], ")"}], "-", 
          RowBox[{"(", 
           RowBox[{"f", "/.", " ", 
            RowBox[{"t", "->", "S2"}]}], ")"}], "-", 
          RowBox[{"(", 
           RowBox[{"f", "/.", " ", 
            RowBox[{"t", "->", "S3"}]}], ")"}]}], ")"}], "/", "4"}], "]"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<   f1 (anti-invariant for S1 and S2): \>\"", ",", "f1"}], 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<   f2 (anti-invariant for S1 and S3): \>\"", ",", "f2"}], 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<   f3 (anti-invariant for S2 and S3): \>\"", ",", "f3"}], 
      "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{"Step", " ", "4"}], ":", " ", 
       RowBox[{
       "Solve", " ", "each", " ", "component", " ", "by", " ", "delegating", 
        " ", "to", " ", 
        RowBox[{"GoursatTheorem1", "."}]}]}], " ", "*)"}], 
     RowBox[{
     "Print", "[", "\"\<Step 4: Applying Theorem 1 to each component...\>\"", 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{
       RowBox[{"Defer", "[", "GoursatTheorem1", "]"}], "[", 
       RowBox[{"f1", ",", "r", ",", "t", ",", "u"}], "]"}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"sol1", "=", 
      RowBox[{"GoursatTheorem1", "[", 
       RowBox[{"f1", ",", "r", ",", "t", ",", "u"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{
       RowBox[{"Defer", "[", "GoursatTheorem1", "]"}], "[", 
       RowBox[{"f2", ",", "r", ",", "t", ",", "u"}], "]"}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"sol2", "=", 
      RowBox[{"GoursatTheorem1", "[", 
       RowBox[{"f2", ",", "r", ",", "t", ",", "u"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{
       RowBox[{"Defer", "[", "GoursatTheorem1", "]"}], "[", 
       RowBox[{"f3", ",", "r", ",", "t", ",", "u"}], "]"}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"sol3", "=", 
      RowBox[{"GoursatTheorem1", "[", 
       RowBox[{"f3", ",", "r", ",", "t", ",", "u"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{"Step", " ", "5"}], ":", " ", 
       RowBox[{
       "The", " ", "final", " ", "result", " ", "is", " ", "the", " ", "sum", 
