  RowBox[{
   FractionBox[
    RowBox[{"1", "+", "x"}], 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "+", "x", "+", 
       SuperscriptBox["x", "2"]}], ")"}], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"a", "+", 
        RowBox[{"b", " ", 
         SuperscriptBox["x", "3"]}]}], ")"}], 
      RowBox[{"1", "/", "3"}]]}]], ",", "x"}], "]"}]], "Input",
