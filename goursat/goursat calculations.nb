Cell[BoxData[
 RowBox[{"linearRationalSubstitute", "[", 
  RowBox[{
   FractionBox[
    RowBox[{"1", "+", 
     RowBox[{"2", " ", "x"}], "+", 
     RowBox[{"2", " ", 
      SuperscriptBox["x", "3"]}], "-", 
     SuperscriptBox["x", "4"]}], 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"2", " ", "x"}], "-", 
       RowBox[{"2", " ", 
        SuperscriptBox["x", "3"]}]}], ")"}], " ", 
     SqrtBox[
      RowBox[{
       RowBox[{"-", "x"}], "+", 
       SuperscriptBox["x", "3"]}]]}]], ",", 
   RowBox[{"u", "->", 
    FractionBox[
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      SqrtBox["2"], "+", "x"}], 
     RowBox[{
      RowBox[{"-", "1"}], "-", 
      SqrtBox["2"], "+", "x"}]]}], ",", "x"}], "]"}]], "Input",
 CellChangeTimes->{{3.963996609935452*^9, 3.9639966189593*^9}},
 CellLabel->
  "In[8359]:=",ExpressionUUID->"bb68ca68-3291-4baa-b67c-6b269278e5c4"],

Cell[BoxData[
 RowBox[{"-", 
  FractionBox[
   RowBox[{"8", " ", "u", " ", 
    RowBox[{"(", 
     RowBox[{"2", "-", 
      SqrtBox["2"], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"2", "+", 
         SqrtBox["2"]}], ")"}], " ", 
       SuperscriptBox["u", "2"]}]}], ")"}]}], 
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "1"}], "+", "u"}], ")"}], "5"], " ", 
    RowBox[{"(", 
     RowBox[{"1", "+", "u"}], ")"}], " ", 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      SqrtBox["2"], "+", "u", "+", 
      RowBox[{
       SqrtBox["2"], " ", "u"}]}], ")"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      SqrtBox["2"], "+", "u", "+", 
      RowBox[{
       SqrtBox["2"], " ", "u"}]}], ")"}], " ", 
    SqrtBox[
     RowBox[{"3", "-", 
      RowBox[{"2", " ", 
       SqrtBox["2"]}], "-", 
      RowBox[{"6", " ", 
       SuperscriptBox["u", "2"]}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"3", "+", 
         RowBox[{"2", " ", 
          SqrtBox["2"]}]}], ")"}], " ", 
       SuperscriptBox["u", "4"]}]}]]}]]}]], "Output",
 CellChangeTimes->{{3.963996620623898*^9, 3.963996668930862*^9}, {
