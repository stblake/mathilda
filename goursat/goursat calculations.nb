Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"GoursatTheorem1", "::", "usage"}], "=", 
    "\"\<GoursatTheorem1[f, r, t] attempts to reduce a pseudo-elliptic \
integral  Integrate[f/Sqrt[r], t] based on Goursat's theorem.\n It finds the \
appropriate root-permuting involution S(t), checks if f(t) is anti-invariant  \
under S(t), and performs a two-step change of variables to solve the \
integral.\>\""}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Clear", "[", "S", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"S", "[", 
    RowBox[{"t_", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"a_", ",", "b_"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"c_", ",", "d_"}], "}"}]}], "}"}]}], "]"}], ":=", 
   RowBox[{"Which", "[", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{
     "Case", " ", "where", " ", "one", " ", "root", " ", "in", " ", "the", 
      " ", "second", " ", "pair", " ", "is", " ", 
      RowBox[{"Infinity", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"d", "===", "Infinity"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"c", "*", 
         RowBox[{"(", 
          RowBox[{"t", "-", "a", "-", "b"}], ")"}]}], "+", 
        RowBox[{"a", "*", "b"}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"t", "-", "c"}], ")"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Case", " ", "where", " ", "one", " ", "root", " ", "in", " ", "the", 
       " ", "first", " ", "pair", " ", "is", " ", 
       RowBox[{"Infinity", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"b", "===", "Infinity"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"a", "*", 
         RowBox[{"(", 
          RowBox[{"t", "-", "c", "-", "d"}], ")"}]}], "+", 
        RowBox[{"c", "*", "d"}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"t", "-", "a"}], ")"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{"Default", " ", 
       RowBox[{"case", ":", 
        RowBox[{"All", " ", "roots", " ", "are", " ", 
         RowBox[{"finite", "."}]}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
     "True", ",", "\[IndentingNewLine]", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"sumab", "=", 
          RowBox[{"a", "+", "b"}]}], ",", 
         RowBox[{"prodab", "=", 
          RowBox[{"a", "*", "b"}]}], ",", 
         RowBox[{"sumcd", "=", 
          RowBox[{"c", "+", "d"}]}], ",", 
         RowBox[{"prodcd", "=", 
          RowBox[{"c", "*", "d"}]}]}], "}"}], ",", 
       RowBox[{"Cancel", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"prodab", "-", "prodcd"}], ")"}], "*", "t"}], "+", 
           RowBox[{"sumab", "*", "prodcd"}], "-", 
           RowBox[{"sumcd", "*", "prodab"}]}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"sumab", "-", "sumcd"}], ")"}], "*", "t"}], "-", 
           RowBox[{"(", 
            RowBox[{"prodab", "-", "prodcd"}], ")"}]}], ")"}]}], "]"}]}], 
      "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "GoursatTheorem1", "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"GoursatTheorem1", "[", 
   RowBox[{"f_", ",", "r_", ",", "t_", ",", "u_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"integrand", "=", 
       RowBox[{"f", "/", 
        RowBox[{"Sqrt", "[", "r", "]"}]}]}], ",", " ", "degree", ",", 
      "finiteRoots", ",", "roots", ",", "pairings", ",", "Slist", ",", "Svol",
       ",", "doublePoints", ",", "alpha", ",", "beta", ",", "usub", ",", 
      "integrandInU", ",", "integrandInX", ",", "integralInX", ",", 
      "finalResult"}], "}"}], ",", "\[IndentingNewLine]", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Step", " ", "1"}], ":", " ", 
       RowBox[{
       "Find", " ", "the", " ", "three", " ", "involutions", " ", "S1"}]}], 
      ",", "S2", ",", 
      RowBox[{"S3", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"degree", "=", 
      RowBox[{"Exponent", "[", 
       RowBox[{"r", ",", "t"}], "]"}]}], ";", 
     RowBox[{"(*", " ", 
      RowBox[{"Get", " ", "the", " ", "degree", " ", "of", " ", "the", " ", 
       RowBox[{"polynomial", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{"Initialize", " ", "roots", " ", 
       RowBox[{"variable", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"roots", "=", 
      RowBox[{"{", "}"}]}], ";", " ", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Which", "[", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{"Case", " ", "1"}], ":", " ", 
        RowBox[{"R", 
         RowBox[{"(", "t", ")"}], " ", "is", " ", "a", " ", 
         RowBox[{"Quartic", "."}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"degree", "==", "4"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"roots", "=", 
         RowBox[{"t", "/.", " ", 
          RowBox[{"Solve", "[", 
           RowBox[{
            RowBox[{"r", "==", "0"}], ",", "t"}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"Length", "[", "roots", "]"}], "!=", "4"}], "||", 
           RowBox[{
            RowBox[{"Length", "[", 
             RowBox[{"DeleteDuplicates", "[", "roots", "]"}], "]"}], "!=", 
            "4"}]}], ",", 
          RowBox[{
           RowBox[{
           "Print", "[", 
            "\"\<Error: Quartic polynomial R(t) must have 4 distinct roots.\>\
\"", "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"Return", "[", "$Failed", "]"}], ";"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{"\"\<Quartic detected. Roots: \>\"", ",", "roots"}], "]"}], 
        ";"}], ",", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{"Case", " ", "2"}], ":", " ", 
         RowBox[{"R", 
          RowBox[{"(", "t", ")"}], " ", "is", " ", "a", " ", 
          RowBox[{"Cubic", "."}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"degree", "==", "3"}], ",", 
       RowBox[{
        RowBox[{"finiteRoots", "=", 
         RowBox[{"t", "/.", " ", 
          RowBox[{"Solve", "[", 
           RowBox[{
            RowBox[{"r", "==", "0"}], ",", "t"}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"Length", "[", "finiteRoots", "]"}], "!=", "3"}], "||", 
           RowBox[{
            RowBox[{"Length", "[", 
             RowBox[{"DeleteDuplicates", "[", "finiteRoots", "]"}], "]"}], "!=",
             "3"}]}], ",", 
          RowBox[{
           RowBox[{
           "Print", "[", 
            "\"\<Error: Cubic polynomial R(t) must have 3 distinct \
roots.\>\"", "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"Return", "[", "$Failed", "]"}], ";"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"roots", "=", 
         RowBox[{"Append", "[", 
          RowBox[{"finiteRoots", ",", "Infinity"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{
         "\"\<Cubic detected. Treating as a quartic with roots: \>\"", ",", 
          "roots"}], "]"}], ";"}], ",", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{"Default", " ", 
         RowBox[{"Case", ":", " ", 
          RowBox[{"Invalid", " ", 
           RowBox[{"Degree", "."}]}]}]}], " ", "*)"}], "True", ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
        "Print", "[", 
         "\"\<Error: R(t) must be a polynomial of degree 3 or 4.\>\"", "]"}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"Return", "[", "$Failed", "]"}]}]}], "\[IndentingNewLine]", 
      "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "2.", " ", "Find", " ", "the", " ", "3", " ", "possible", " ", 
       "involutions", " ", "S", 
       RowBox[{"(", "t", ")"}], " ", "that", " ", "permute", " ", "roots", 
       " ", "in", " ", 
       RowBox[{"pairs", "."}]}], " ", "*)"}], 
     RowBox[{
     "Print", "[", 
      "\"\<\\nStep 2: Finding possible involutive substitutions S(t)...\>\"", 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"pairings", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"roots", "[", 
             RowBox[{"[", "1", "]"}], "]"}], ",", 
            RowBox[{"roots", "[", 
             RowBox[{"[", "2", "]"}], "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"roots", "[", 
             RowBox[{"[", "3", "]"}], "]"}], ",", 
            RowBox[{"roots", "[", 
             RowBox[{"[", "4", "]"}], "]"}]}], "}"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"roots", "[", 
             RowBox[{"[", "1", "]"}], "]"}], ",", 
            RowBox[{"roots", "[", 
             RowBox[{"[", "3", "]"}], "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"roots", "[", 
             RowBox[{"[", "2", "]"}], "]"}], ",", 
            RowBox[{"roots", "[", 
             RowBox[{"[", "4", "]"}], "]"}]}], "}"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"roots", "[", 
             RowBox[{"[", "1", "]"}], "]"}], ",", 
            RowBox[{"roots", "[", 
             RowBox[{"[", "4", "]"}], "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"roots", "[", 
             RowBox[{"[", "2", "]"}], "]"}], ",", 
            RowBox[{"roots", "[", 
             RowBox[{"[", "3", "]"}], "]"}]}], "}"}]}], "}"}]}], "}"}]}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"Slist", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"S", "[", 
         RowBox[{"t", ",", "#"}], "]"}], "&"}], "/@", "pairings"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<   Possible involutions: \>\"", ",", "Slist"}], "]"}], ";",
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
        RowBox[{
        "3.", " ", "Check", " ", "which", " ", "involution", " ", "satisfies",
          " ", "F", 
         RowBox[{"(", "t", ")"}]}], "+", 
        RowBox[{"F", 
         RowBox[{"(", 
          RowBox[{"S", 
           RowBox[{"(", "t", ")"}]}], ")"}]}]}], "==", "0"}], " ", "*)"}], 
     RowBox[{
     "Print", "[", 
      "\"\<\\nStep 3: Checking the anti-invariance condition F(t) + F(S(t)) = \
0...\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Svol", "=", 
      RowBox[{"SelectFirst", "[", 
       RowBox[{"Slist", ",", 
        RowBox[{
         RowBox[{
          RowBox[{"Simplify", "[", 
           RowBox[{"Cancel", "[", 
            RowBox[{"Together", "[", 
             RowBox[{"f", "+", 
              RowBox[{"(", 
               RowBox[{"f", "/.", " ", 
                RowBox[{"t", "->", "#"}]}], ")"}]}], "]"}], "]"}], "]"}], "==",
           "0"}], "&"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"Svol", "===", 
        RowBox[{"Missing", "[", "\"\<NotFound\>\"", "]"}]}], ",", 
       RowBox[{
        RowBox[{
        "Print", "[", 
         "\"\<Error: The function F(t) is not anti-invariant under any of the \
3 involutions. The theorem does not apply.\>\"", "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Return", "[", 
         RowBox[{
          RowBox[{"Defer", "[", "Integrate", "]"}], "[", 
          RowBox[{"integrand", ",", "t"}], "]"}], "]"}], ";"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{
      "\"\<Success! Found a valid involution: S(t) = \>\"", ",", "Svol"}], 
      "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
       "4.", " ", "Find", " ", "the", " ", "double", " ", "points", " ", "of",
         " ", "the", " ", "involution"}], ",", 
       RowBox[{
       "which", " ", "are", " ", "fixed", " ", "points", " ", "of", " ", "S", 
        
        RowBox[{
         RowBox[{"(", "t", ")"}], "."}]}]}], " ", "*)"}], 
     RowBox[{
     "Print", "[", 
      "\"\<\\nStep 4: Finding the double points of the involution \
S(t)...\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"doublePoints", "=", 
      RowBox[{"Solve", "[", 
       RowBox[{
        RowBox[{"Svol", "==", "t"}], ",", "t"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "[", "doublePoints", "]"}], "==", "2"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"alpha", "=", 
         RowBox[{"t", "/.", " ", 
          RowBox[{"doublePoints", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"beta", "=", 
         RowBox[{"t", "/.", " ", 
          RowBox[{"doublePoints", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"usub", "=", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"t", "-", "alpha"}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{"t", "-", "beta"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
        
        RowBox[{"Print", "[", 
         RowBox[{
         "\"\<   Double points (\[Alpha], \[Beta]): {\>\"", ",", "alpha", 
          ",", "\"\<, \>\"", ",", "beta", ",", "\"\<}\>\""}], "]"}], ";"}], 
       ",", 
       RowBox[{"(*", 
        RowBox[{
        "Handle", " ", "the", " ", "special", " ", "case", " ", "where", " ", 
         "one", " ", "double", " ", "point", " ", "is", " ", "at", " ", 
