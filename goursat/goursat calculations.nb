       SuperscriptBox["x", "3"]}], "-", 
      RowBox[{"2", " ", "\[ImaginaryI]", " ", 
       SqrtBox["2"], " ", "x", " ", 
       SqrtBox[
        RowBox[{"4", "-", 
         RowBox[{"5", " ", 
          SuperscriptBox["x", "2"]}], "+", 
         SuperscriptBox["x", "4"]}]]}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "2"}], "+", 
         SuperscriptBox["x", "2"]}], ")"}], " ", 
       SqrtBox[
        RowBox[{"4", "-", 
         RowBox[{"5", " ", 
          SuperscriptBox["x", "2"]}], "+", 
         SuperscriptBox["x", "4"]}]]}]}]], "]"}]}]}]], "Output",
