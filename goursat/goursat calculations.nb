Cell[BoxData[
 RowBox[{
  RowBox[{"linearRationalSubstitute", "[", 
   RowBox[{"expr_", ",", " ", 
    RowBox[{"u_", "->", "sub_"}], ",", "x_"}], "]"}], ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"xsub", ",", "expru"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"xsub", "=", 
      RowBox[{
       RowBox[{"Solve", "[", 
        RowBox[{
         RowBox[{"u", "==", "sub"}], ",", "x"}], "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"expru", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"expr", "/.", "xsub"}], ")"}], " ", 
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"x", "/.", 
          RowBox[{"xsub", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], ",", "u"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "expru", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"expru", "=", 
      RowBox[{
       RowBox[{"MapAll", "[", 
        RowBox[{"Together", ",", "expru"}], "]"}], "/.", 
       RowBox[{
        RowBox[{"Power", "[", 
         RowBox[{
          RowBox[{"e_", "/", 
           SuperscriptBox["p_", "3"]}], ",", 
          RowBox[{"r", ":", 
           RowBox[{
            RowBox[{"1", "/", "2"}], "|", 
            RowBox[{
             RowBox[{"-", "1"}], "/", "2"}]}]}]}], "]"}], ":>", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"p", " ", "e"}], ")"}], "r"], "/", 
         SuperscriptBox["p", "2"]}]}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"expru", "/.", 
         RowBox[{
          RowBox[{"p_", "/;", 
           RowBox[{"PolynomialQ", "[", 
            RowBox[{"p", ",", "u"}], "]"}]}], ":>", 
          RowBox[{"Collect", "[", 
           RowBox[{"p", ",", "u", ",", "Together"}], "]"}]}]}], "//", 
        "Simplify"}], "//", "PowerExpand"}], "//", "Simplify"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.9639891953631353`*^9, 3.963989206219746*^9}, {
  3.963989283781781*^9, 3.963989295843358*^9}, {3.9639962910317717`*^9, 
  3.9639963739848747`*^9}, {3.963996451053308*^9, 3.963996493647707*^9}, {
  3.963996570049508*^9, 3.963996595903187*^9}, {3.963996637820447*^9, 
  3.9639966677790623`*^9}, {3.9639967104663887`*^9, 3.9639967381512833`*^9}, {
  3.963996798358358*^9, 3.963996827693269*^9}, {3.963997270589324*^9, 
  3.963997277110015*^9}, {3.963997321524003*^9, 3.9639973221644907`*^9}, {
  3.963997697484234*^9, 3.9639977018944483`*^9}},
 CellLabel->
  "In[8382]:=",ExpressionUUID->"c3bda664-d219-4cac-ab48-3584f11e382f"],

