{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Mathilda notebook permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-spawn",
